# ReguMind Environment Variables
# Copy this file to .env and fill in your values
# Never commit your actual .env file to GitHub

# Required: Get your free API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenAI key (not required, Groq is used instead)
OPENAI_API_KEY=your_openai_api_key_here

# Database (automatically configured in Docker, change only if running locally)
DATABASE_URL=postgresql://postgres:regumind123@localhost:5432/regumind

# Qdrant (automatically configured in Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333